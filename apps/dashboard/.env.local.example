# Supabase project config (mesmo projeto do apps/web).
# Get these from: Supabase Dashboard > Project Settings > API
# Copy this file to `.env.local` and fill in the values.
#
# Antes de rodar o dashboard:
#   1. "Google" já deve estar habilitado como provider (mesmo do apps/web).
#   2. Adicione o callback do dashboard à "Redirect URLs" allowlist do Supabase:
#      http://localhost:3001/auth/callback  (development)
#      https://admin.seudominio.com/auth/callback (production)
#   3. Rode as migrations: `supabase db push` (inclui `admin_users`).
#   4. Cadastre manualmente o primeiro admin via SQL editor do Supabase:
#      insert into public.admin_users (email) values ('voce@exemplo.com');

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret (NUNCA prefixar com NEXT_PUBLIC / nunca expor ao cliente).
# Service role key: Supabase Dashboard > Project Settings > API > "service_role".
# O dashboard usa a service role para (a) checar a allowlist admin_users no
# middleware/callback e (b) ler dados agregados cross-usuário (bypassa RLS).
SUPABASE_SERVICE_ROLE_KEY=
