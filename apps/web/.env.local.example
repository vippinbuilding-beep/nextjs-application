# Supabase project config.
# Get these from: Supabase Dashboard > Project Settings > API
# Copy this file to `.env.local` and fill in the values.
#
# Before running the app, also make sure to:
#   1. Enable "Google" as a provider in Supabase Dashboard > Authentication > Providers
#      (requires a Google OAuth Client ID + Secret from Google Cloud Console)
#   2. Add your callback URL to the Supabase "Redirect URLs" allowlist:
#      http://localhost:3000/auth/callback  (development)
#      https://yourdomain.com/auth/callback (production)
#   3. Run migrations: `supabase db push`
#   4. For video uploads > 50 MB: Supabase Dashboard > Project Settings > Storage
#      → raise "Global file size limit" (requires Pro plan for files > 50 MB)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL used for Open Graph / share previews (no trailing slash).
# Development: http://localhost:3000
# Production:  https://www.vippin.com.br
NEXT_PUBLIC_SITE_URL=

# Facebook App ID for Open Graph (Sharing Debugger / WhatsApp previews).
# Create an app at https://developers.facebook.com/apps/ and paste the App ID here.
FACEBOOK_APP_ID=

# Support/contact email shown as a "Fale conosco" link (mailto:) on the landing
# page footer. Leave empty to hide the link.
NEXT_PUBLIC_CONTACT_EMAIL=

# Server-only secrets (NEVER expose these to the client / never prefix with NEXT_PUBLIC).
# Service role key: Supabase Dashboard > Project Settings > API > "service_role".
# Used only in Route Handlers to sign short-lived URLs for the PRIVATE products bucket.
SUPABASE_SERVICE_ROLE_KEY=
# Random secret used to sign short-lived media access tokens.
# Generate one with: openssl rand -base64 32
MEDIA_TOKEN_SECRET=

# AbacatePay
ABACATEPAY_WEBHOOK_SECRET=
ABACATEPAY_API_KEY=

# Dev mode: simulates `/pix/send` locally (AbacatePay sandbox does not support
# outbound transfers). Defaults to true when NODE_ENV=development. Set to
# `false` to call the real API with a production key while running locally.
# ABACATEPAY_DEV_MODE=true

# Cron worker auth (Vercel sends `Authorization: Bearer <CRON_SECRET>` automatically).
# Weekly creator payouts: `/api/cron/weekly-creator-payouts` (Mondays 10:00 BRT).
# Generate one with: openssl rand -base64 32
CRON_SECRET=

# Pagamentos / repasse ao criador
# Taxa da plataforma em cada venda (inteiro, ex.: 10 = 10%). Por venda também
# entra R$ 0,80 fixo; no saque há mais R$ 0,80 de taxa PIX. Padrão: 10
NEXT_PUBLIC_PLATFORM_FEE_PERCENT=10

# Saldo mínimo para saque manual do criador, em centavos (2000 = R$ 20,00)
CREATOR_MIN_WITHDRAWAL_CENTS=2000