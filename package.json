{
  "name": "vippin",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@vippin/web",
    "dev:dashboard": "turbo run dev --filter=@vippin/dashboard",
